{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/check-giveaways?secret=@webhook_secret",
      "schedule": "*/1 * * * *"
    }
  ]
}
